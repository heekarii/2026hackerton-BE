DATABASE_URL=postgresql://postgres:password@localhost:5432/campus_complaints
JWT_SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
EMAIL_VERIFICATION_SECRET=replace-with-another-long-random-secret
EMAIL_VERIFICATION_CODE_EXPIRE_MINUTES=10
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=30
EMAIL_VERIFICATION_RESEND_SECONDS=60
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
SCHOOL_EMAIL_DOMAINS=sju.ac.kr

# Gmail SMTP: Google 계정의 일반 비밀번호가 아닌 16자리 앱 비밀번호를 사용합니다.
EMAIL_VERIFICATION_DEBUG=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=sender@gmail.com
SMTP_PASSWORD=replace-with-google-app-password
SMTP_FROM_EMAIL=sender@gmail.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

OPENAPI_URL=/openapi.json
DOCS_URL=/docs
REDOC_URL=/redoc
CORS_ORIGINS=http://localhost:5173,https://2026hackerton-fe.vercel.app
