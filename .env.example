SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

OPENAPI_URL=/openapi.json
DOCS_URL=/docs
REDOC_URL=/redoc
